# Core
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=product_scraper
POSTGRES_PORT=5432
REDIS_PORT=6379

# API
API_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/product_scraper
REDIS_URL=redis://redis:6379/0
RQ_QUEUE_NAME=product-scraper
JOB_RATE_LIMIT_PER_MINUTE=10
REQUEST_TIMEOUT_SECONDS=12
PLAYWRIGHT_TIMEOUT_SECONDS=15000
MAX_FETCH_RETRIES=2
SCRAPER_CONCURRENCY=6
CACHE_TTL_HOURS=24
SEARCH_PROVIDER=google
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
SERPAPI_API_KEY=
USER_AGENT=RomaniaProductDiscoveryBot/1.0 (+contact: admin@example.com)

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
WEB_PORT=3000
