# Core
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=product_scraper
POSTGRES_PORT=5432

# API
API_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/product_scraper
JOB_RATE_LIMIT_PER_MINUTE=10
REQUEST_TIMEOUT_SECONDS=12
PLAYWRIGHT_TIMEOUT_SECONDS=15000
MAX_FETCH_RETRIES=2
SCRAPER_CONCURRENCY=6
SCRAPE_BATCH_SIZE=25
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_KEEPALIVE_CONNECTIONS=40
FETCH_CACHE_TTL_SECONDS=600
MANUAL_TOP_URLS_PER_DOMAIN=3
CACHE_TTL_HOURS=24
SEARCH_PROVIDER=manual
ALLOWED_DOMAINS=pepinieraperis.ro,pepinieracalugareni.ro,pepiniera-emma.ro,pepinieracomana.ro,pepinierele-roman.ro,agrodenmar.ro,gradinadinsud.ro,icas.ro,scdpbaneasa.ro,plantedevis.ro,plantedecorative.com,taotao-gradinarul.ro,garden-center.ro,secretgarden.ro,verdena.ro,plantup.ro,primitivplants.ro,flowerstation.ro,sweetgarden.ro,plantshop.ro,urbangarden.ro,greengarden.ro,floria.ro,floridelux.ro,florariairis.ro,triasflowers.ro,ideafiori.ro,pastelflowers.ro,hornbach.ro,dedeman.ro,leroymerlin.ro,bricodepot.ro,plantmania.ro,florigradina.ro,plantland.ro,gradinamax.ro,plantedecorative.ro
USER_AGENT=RomaniaProductDiscoveryBot/1.0 (+contact: admin@example.com)

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
WEB_PORT=3000
